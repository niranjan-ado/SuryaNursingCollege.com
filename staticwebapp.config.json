      "redirect": "/admissions",
      "statusCode": 301
    },
    {
      "route": "/faq.html",
      "redirect": "/faq",
      "statusCode": 301
    },
    {
      "route": "/contact.html",
      "redirect": "/contact",
      "statusCode": 301
    },
    {
      "route": "/blog.html",
      "redirect": "/blog",
      "statusCode": 301
    },
    {
      "route": "/anm-syllabus.html",
      "redirect": "/anm-syllabus",
      "statusCode": 301
    },
    {
      "route": "/gnm-syllabus.html",
